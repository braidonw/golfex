<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Golfex" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <nav class="navbar">
      <div class="navbar__inner wrapper">
        <.link href={~p"/"} class="navbar__logo" aria-label="Golfex home">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44" fill="none" aria-hidden="true" class="navbar__logo-icon">
            <rect x="14" y="4" width="2.5" height="32" rx="1.25" fill="currentColor"/>
            <path d="M16.5 4 L36 11 L16.5 18Z" fill="#16a34a"/>
            <ellipse cx="15" cy="38" rx="11" ry="3" fill="currentColor" opacity="0.3"/>
            <circle cx="28" cy="34" r="5" fill="currentColor" opacity="0.85"/>
            <circle cx="26.5" cy="32.5" r="1" fill="white" opacity="0.4"/>
          </svg>
          <span class="navbar__logo-text">Golf<span class="navbar__logo-accent">ex</span></span>
        </.link>

        <button
          class="navbar__toggle"
          aria-label="Toggle menu"
          aria-expanded="false"
          phx-click={
            Phoenix.LiveView.JS.toggle(to: "#mobile-nav", display: "flex")
            |> Phoenix.LiveView.JS.toggle_attribute({"aria-expanded", "true", "false"}, to: "#menu-toggle")
            |> Phoenix.LiveView.JS.toggle_attribute({"data-open", "true"}, to: "#mobile-nav")
          }
          id="menu-toggle"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>

        <ul class="navbar__links" role="list" id="mobile-nav">
          <%= if @current_scope do %>
            <li class="navbar__user">{@current_scope.user.email}</li>
            <li><.link href={~p"/"}>Dashboard</.link></li>
            <li><.link href={~p"/clubs"}>Clubs</.link></li>
            <li><.link href={~p"/bookings"}>My Bookings</.link></li>
            <li><.link href={~p"/users/settings"}>Settings</.link></li>
            <li><.link href={~p"/users/log-out"} method="delete">Log out</.link></li>
          <% else %>
            <li><.link href={~p"/users/log-in"}>Log in</.link></li>
          <% end %>
        </ul>
      </div>
    </nav>
    {@inner_content}
    <script>
      // Highlight active nav link
      (function() {
        function setActive() {
          var path = window.location.pathname;
          document.querySelectorAll('.navbar__links a').forEach(function(a) {
            var href = a.getAttribute('href');
            if (!href) return;
            // Exact match for root, prefix match for others
            var isActive = href === '/' ? path === '/' : path.startsWith(href);
            if (isActive) a.setAttribute('aria-current', 'page');
            else a.removeAttribute('aria-current');
          });
        }
        setActive();
        document.addEventListener('phx:page-loading-stop', setActive);
      })();
    </script>
  </body>
</html>
